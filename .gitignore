.opencode/metrics/task-outcomes.jsonl
!.opencode/metrics/reports/

# ─────────────────────────────────────────────────────────────
# Workspace Ignore Safety Guard (P1A-C, 2026-06-05)
# Prevents accidental staging of Doppler secrets, fd developer
# tooling, example-agent runtime context, auto-generated digests, and
# other local-only artifacts that should never reach the index.
# ─────────────────────────────────────────────────────────────

# Local secret/env files (Doppler-managed; never commit)
**/.env.doppler

# Local developer tooling
**/.fdignore
**/.example-agent.md

# Generated reports / local artifacts
ProjectTracker/reports/
.playwright-mcp/
.superpowers/

# Optional local example-agent checkout; not required for protocol reproducibility
example-agent/example-agent/

# ─────────────────────────────────────────────────────────────
# Multi-Repo Workspace Hygiene (v4.15.1, Phase 1B)
# Added: 2026-06-29
# Non-destructive ignore rules to make root workspace auditable.
# Does not delete, move, or modify any files.
# ─────────────────────────────────────────────────────────────

# Product repos with their own .git (managed separately)
/protected-repo/
/protected-repo-prod/
/example-platform/
/example-toolchain-PROD/
/example-orchestrator-PROD/
/trace-eval/
/agent-ready/
/ai-agents/
/analytics/
/productivity/
/web-apps/

# Workspace-local Misc projects (not protocol, not product repos)
/Misc/

# Private/personal data (never commit)
/Family Insurance/

# Claude config (Release 2 track, not OpenCode protocol)
/.claude/

# OpenCode generated artifacts
/.opencode/evals/*
!.opencode/evals/baseline-tasks.yaml
!.opencode/evals/task-replay
!.opencode/evals/loop-runs
!.opencode/evals/lessons
/.opencode/benchmarks/benchmark-results/
/.opencode/benchmarks/model-snapshots/
/.opencode/benchmarks/*-evidence-report.md
/.opencode/benchmarks/*-canary-*.md
/.opencode/benchmarks/*-completion-summary.md
/.opencode/benchmarks/*-production-smoke-*.md
/.opencode/benchmarks/*-production-ready-*.md
/.opencode/benchmarks/*-runtime-benchmark.md
/.opencode/benchmarks/*-integrity-audit.md
/.opencode/benchmarks/*-candidate-*.md
/.opencode/benchmarks/*-onboarding.md

# Archived/disabled local protocol artifacts
# v4.53.1 Archive untracked (historical, not needed for protocol operation)
# Canonical history lives in vault/protocols/opencode/
/.opencode/archive//.opencode/plugins.disabled-*/

# Local workspace inventory artifacts (not protocol)
/AI_WORKSTATION_SUITE.md
/DOCS_FRESHNESS.yaml
/WORKSPACE_CATALOG.yaml
/WORKSPACE_CLEANUP_SUMMARY.md
/WORKSPACE_DEEP_AUDIT_REPORT.md
/skills-analysis.json

# Local git-guard runtime log (generated, not source)
/.opencode/git-guard/override-log.jsonl

